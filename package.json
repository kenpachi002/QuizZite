{
  "name": "quizzite",
  "version": "1.0.0",
  "description": "Interactive quiz application powered by GROQ AI",
  "main": "backend.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\" \"npm run open:browser\"",
    "dev:client": "vite",
    "dev:server": "node backend.js",
    "open:browser": "start http://localhost:5173",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node backend.js",
    "start:backend": "node backend.js"
  },
  "keywords": [
    "quiz",
    "ai",
    "react",
    "groq"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "axios": "^1.6.0",
    "concurrently": "^8.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.0"
  }
}